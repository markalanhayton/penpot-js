# Penpot Node.js Backend Configuration
# Copy this file to .env and customize values for your environment.

# --- Database ---
# Path to the SQLite database file. Use ':memory:' for ephemeral in-memory storage.
PENPOT_DATABASE_PATH=penpot.sqlite

# --- HTTP Server ---
PENPOT_HTTP_HOST=0.0.0.0
PENPOT_HTTP_PORT=6060
# Maximum request body size in bytes (default: 350 MB)
# PENPOT_HTTP_MAX_BODY_SIZE=367001600

# --- Authentication ---
# IMPORTANT: Change this in production! The default is for development only.
PENPOT_SECRET_KEY=penpot-dev-secret-key-change-me
PENPOT_AUTH_TOKEN_COOKIE_NAME=auth-token
# Cookie max age in seconds (default: 7 days)
# PENPOT_AUTH_TOKEN_COOKIE_MAX_AGE=604800
# Session renewal threshold in seconds (default: 6 hours)
# PENPOT_AUTH_SESSION_RENEWAL_AGE=21600

# --- Public URL ---
# The externally-reachable URL for this Penpot instance.
PENPOT_PUBLIC_URI=http://localhost:3449
PENPOT_HOST=localhost

# --- Tenant ---
PENPOT_TENANT=default

# --- Feature Flags ---
# Space-separated list: use 'enable-<flag>' or 'disable-<flag>' to override defaults.
# Available flags: registration, login-with-password, export-file-v3, frontend-svgo,
#   backend-api-doc, backend-openapi-doc, backend-worker, secure-session-cookies,
#   email-verification, onboarding, dashboard-templates-section, google-fonts-provider,
#   component-thumbnails, render-wasm-dpr, feature-render-wasm, token-color,
#   token-shadow, inspect-styles, feature-fdata-objects-map, token-import-from-library,
#   access-tokens, webhooks, smtp, mcp, telemetry, quotes
# PENPOT_FLAGS=enable-registration enable-login-with-password

# --- Storage ---
# Storage backend: 'fs' (filesystem) or 's3' (MinIO / AWS S3 / compatible)
PENPOT_STORAGE_BACKEND=fs
PENPOT_STORAGE_FS_DIRECTORY=assets

# --- S3 / MinIO Storage ---
# Required when PENPOT_STORAGE_BACKEND=s3
PENPOT_STORAGE_S3_BUCKET=
PENPOT_STORAGE_S3_REGION=us-east-1
# MinIO example: http://localhost:9000
PENPOT_STORAGE_S3_ENDPOINT=
PENPOT_STORAGE_S3_PREFIX=
PENPOT_STORAGE_S3_ACCESS_KEY=
PENPOT_STORAGE_S3_SECRET_KEY=
# Set to 'true' for MinIO and other path-style S3-compatible servers
PENPOT_STORAGE_S3_PATH_STYLE=false

# --- SMTP (email delivery) ---
PENPOT_SMTP_ENABLED=false
PENPOT_SMTP_HOST=
PENPOT_SMTP_PORT=587
PENPOT_SMTP_USERNAME=
PENPOT_SMTP_PASSWORD=
PENPOT_SMTP_DEFAULT_FROM=Penpot <no-reply@example.com>
PENPOT_SMTP_DEFAULT_REPLY_TO=Penpot <no-reply@example.com>
PENPOT_SMTP_SSL=false
PENPOT_SMTP_TLS=false

# --- LDAP (optional, for SSO) ---
PENPOT_LDAP_ENABLED=false
PENPOT_LDAP_HOST=
PENPOT_LDAP_PORT=389
PENPOT_LDAP_SSL=false
PENPOT_LDAP_STARTTLS=false
PENPOT_LDAP_BASE_DN=
PENPOT_LDAP_BIND_DN=
PENPOT_LDAP_BIND_PASSWORD=
PENPOT_LDAP_ATTRS_USERNAME=uid
PENPOT_LDAP_ATTRS_EMAIL=mail
PENPOT_LDAP_ATTRS_FULLNAME=cn
PENPOT_LDAP_ATTRS_PHOTO=jpegPhoto
PENPOT_LDAP_USER_QUERY=(|(uid=:username)(mail=:username))

# --- OpenID Connect (optional, for SSO) ---
PENPOT_OIDC_CLIENT_ID=
PENPOT_OIDC_CLIENT_SECRET=
PENPOT_OIDC_BASE_URI=
PENPOT_OIDC_AUTH_URI=
PENPOT_OIDC_TOKEN_URI=
PENPOT_OIDC_USER_URI=
PENPOT_OIDC_SCOPES=openid profile email
PENPOT_OIDC_ROLES=
PENPOT_OIDC_ROLES_ATTR=roles
PENPOT_OIDC_EMAIL_ATTR=email
PENPOT_OIDC_NAME_ATTR=name
PENPOT_OIDC_USER_INFO_SOURCE=auto

# --- Google OAuth (optional, for SSO) ---
PENPOT_GOOGLE_CLIENT_ID=
PENPOT_GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth (optional, for SSO) ---
PENPOT_GITHUB_CLIENT_ID=
PENPOT_GITHUB_CLIENT_SECRET=

# --- GitLab OAuth (optional, for SSO) ---
PENPOT_GITLAB_CLIENT_ID=
PENPOT_GITLAB_CLIENT_SECRET=
PENPOT_GITLAB_BASE_URI=https://gitlab.com

# --- Media ---
# Maximum upload file size in bytes (default: 30 MB)
# PENPOT_MEDIA_MAX_FILE_SIZE=31457280

# --- Fonts ---
# Maximum font file size in bytes (default: 30 MB)
# PENPOT_FONT_MAX_FILE_SIZE=31457280

# --- Management (shared key for /api/management endpoints) ---
# PENPOT_MANAGEMENT_SHARED_KEY=

# --- Initial Project ---
PENPOT_INITIAL_PROJECT_SKEY=initial-project

# --- Telemetry ---
# Enable periodic telemetry data collection and upload (default: false)
PENPOT_TELEMETRY_ENABLED=false
# Telemetry endpoint URL (default: https://telemetry.penpot.app/)
# PENPOT_TELEMETRY_URI=https://telemetry.penpot.app/
# Referer header value for telemetry requests (default: uses PENPOT_PUBLIC_URI)
# PENPOT_TELEMETRY_REFERER=